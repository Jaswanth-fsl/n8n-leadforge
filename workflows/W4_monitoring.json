        "position": [
          224,
          0
        ],
        "credentials": {
          "postgres": {
            "id": "S3QhRNcrvBHI20yE",
            "name": "Postgres account 2"
          }
        },
        "onError": "continueErrorOutput"
      },
      {
        "parameters": {
          "jsCode": "const row = $input.first().json;\nconst today = new Date().toISOString().split('T')[0];\n\nreturn [{\n  json: {\n    date: today,\n    total_today: parseInt(row.total_today) || 0,\n    score_bands: {\n      high: parseInt(row.high_score_count) || 0,\n      mid: parseInt(row.mid_score_count) || 0,\n      low: parseInt(row.low_score_count) || 0\n    }\n  }\n}];"
        },
