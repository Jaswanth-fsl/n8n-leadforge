      {
        "parameters": {
          "operation": "executeQuery",
          "query": "SELECT\n  COUNT(*) FILTER (WHERE score >= 70) AS high_score_count,\n  COUNT(*) FILTER (WHERE score < 70 AND score >= 40) AS mid_score_count,\n  COUNT(*) FILTER (WHERE score < 40) AS low_score_count,\n  COUNT(*) AS total_today\nFROM leads\nWHERE created_at >= CURRENT_DATE\n  AND created_at < CURRENT_DATE + INTERVAL '1 day';",
          "options": {}
        },
        "id": "a53653c2-27e2-46b0-93c4-27bd4c5e44fe",
        "name": "Query Lead Counts",
        "type": "n8n-nodes-base.postgres",
