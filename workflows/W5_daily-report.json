          }
        },
        "id": "ca7cb9ed-6cd2-485e-8e7b-9aaf01a2a3f2",
        "name": "Schedule 07:00",
        "type": "n8n-nodes-base.scheduleTrigger",
        "typeVersion": 1.2,
        "position": [
          0,
          0
        ]
      },
      {
        "parameters": {
          "operation": "executeQuery",
          "query": "SELECT\n  COUNT(*) AS total,\n  COUNT(*) FILTER (WHERE score >= 70) AS high_score,\n  COUNT(*) FILTER (WHERE score >= 40 AND score < 70) AS mid_score,\n  COUNT(*) FILTER (WHERE score < 40) AS low_score,\n  ROUND(AVG(score), 1) AS avg_score,\n  COUNT(DISTINCT intent) AS unique_intents,\n  MODE() WITHIN GROUP (ORDER BY intent) AS top_intent,\n  MODE() WITHIN GROUP (ORDER BY company_size) AS top_company_size\nFROM leads\nWHERE created_at >= CURRENT_DATE - INTERVAL '1 day'\n  AND created_at < CURRENT_DATE;",
          "options": {}
        },
        "id": "32b739f4-d308-41b2-a217-01cc2c68d006",
        "name": "Query Yesterday Leads",
        "type": "n8n-nodes-base.postgres",
        "typeVersion": 2.5,
        "position": [
          224,
          0
        ],
        "credentials": {
          "postgres": {
            "id": "S3QhRNcrvBHI20yE",
            "name": "Postgres account 2"
          }
        },
        "onError": "continueErrorOutput"
      },
      {
        "parameters": {
          "jsCode": "const row = $input.first().json;\nconst yesterday = new Date();\nyesterday.setDate(yesterday.getDate() - 1);\nconst dateStr = yesterday.toISOString().split('T')[0];\n\nconst total = parseInt(row.total) || 0;\nconst high = parseInt(row.high_score) || 0;\nconst mid = parseInt(row.mid_score) || 0;\nconst low = parseInt(row.low_score) || 0;\nconst avg = parseFloat(row.avg_score) || 0;\n\nconst message = `:bar_chart: *LeadForge Daily Report — ${dateStr}*\\n\\n` +\n  `*Total Leads Processed:* ${total}\\n` +\n  `*Average Score:* ${avg}/100\\n\\n` +\n  `*Score Breakdown:*\\n` +\n  `:green_circle: High (≥70): ${high}\\n` +\n  `:yellow_circle: Mid (40–69): ${mid}\\n` +\n  `:red_circle: Low (<40): ${low}\\n\\n` +\n  `*Top Intent:* ${row.top_intent || 'N/A'}\\n` +\n  `*Top Company Size:* ${row.top_company_size || 'N/A'}\\n\\n` +\n  `_Sent automatically by LeadForge AI_`;\n\nreturn [{ json: { message, date: dateStr, total, high, mid, low, avg } }];"
        },
        "id": "a4667e82-33d3-433f-9b08-12614f7d911c",
        "name": "Format Daily Digest",
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          448,
