        ]
      },
      {
        "parameters": {
          "jsCode": "// Log the error but don't crash the workflow\nconsole.error('Daily report failed:', $json);\nreturn [{ json: { status: 'error', message: 'Daily report delivery failed', timestamp: new Date().toISOString() } }];"
        },
